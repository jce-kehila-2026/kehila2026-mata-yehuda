# Frontend — URL of the FCM notification server (no secrets here)
# In dev, Vite proxy can also forward /api/notifications to localhost:3001
VITE_NOTIFICATIONS_API_URL=http://localhost:3001

# Firebase Cloud Messaging — Web Push certificate (Firebase Console → Project settings → Cloud Messaging)
VITE_FIREBASE_VAPID_KEY=

# Payment API (Vite dev proxies /api → localhost:5001; set explicitly in production)
VITE_API_BASE=http://localhost:5001

# Public site URL for payment/registration links (optional)
VITE_PUBLIC_SITE_URL=http://localhost:5173
