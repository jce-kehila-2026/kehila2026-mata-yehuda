# Frontend (src/) — local dev: copy to .env.local
# Production (Render): set these in the Static Site Environment Variables

# Payment API — Render URL of matayehuda-payment-api (no trailing slash)
# Local dev: leave empty (Vite proxy uses /api)
# VITE_API_BASE=https://matayehuda-payment-api.onrender.com

# Notifications API — Render URL of matayehuda-notifications-api
# VITE_NOTIFICATIONS_API_URL=https://matayehuda-notifications-api.onrender.com

# Firebase client config (Project Settings → Your apps → Web)
# Required for local dev (.env.local) and production (Render env vars)
VITE_FIREBASE_API_KEY=your_firebase_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=matayehuda.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=matayehuda
VITE_FIREBASE_STORAGE_BUCKET=matayehuda.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=264845791661
VITE_FIREBASE_APP_ID=your_firebase_web_app_id

# Firebase Cloud Messaging — Web Push key pair
# Project Settings → Cloud Messaging → Web Push certificates
VITE_FIREBASE_VAPID_KEY=
