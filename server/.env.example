PORT=3001

# Firebase Admin — verify staff ID tokens and send FCM (path to service account JSON)
# Path from project root when running: node server/server.js
GOOGLE_APPLICATION_CREDENTIALS=./server/serviceAccountKey.json
FIREBASE_PROJECT_ID=matayehuda

# Payment server (server.js on port 5001) — same Firebase vars or use GOOGLE_APPLICATION_CREDENTIALS above
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com
# FRONTEND_URL=http://localhost:5173
# STAFF_PIN=

# Optional: restrict CORS to your app origin
CLIENT_ORIGIN=http://localhost:5173

# Skip notification tokens inactive for more than N days (default 90)
FCM_TOKEN_STALE_DAYS=90
