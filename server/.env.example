PORT=3001

# Firebase Admin — verify staff ID tokens and send FCM (path to service account JSON)
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
FIREBASE_PROJECT_ID=matayehuda

# Optional: restrict CORS to your app origin
CLIENT_ORIGIN=http://localhost:5173

# Skip notification tokens inactive for more than N days (default 90)
FCM_TOKEN_STALE_DAYS=90
