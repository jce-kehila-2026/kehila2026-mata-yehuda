PORT=3001

# Firebase Admin — verify staff ID tokens (path to service account JSON)
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
FIREBASE_PROJECT_ID=matayehuda

# Optional: restrict CORS to your app origin
CLIENT_ORIGIN=http://localhost:5173

# Meta WhatsApp Cloud API (never expose in frontend)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_GRAPH_API_VERSION=v21.0

# template = marketing/broadcast (requires approved template in Meta)
# text = session message (only if user messaged you within 24h)
WHATSAPP_MESSAGE_MODE=template
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANGUAGE=he
