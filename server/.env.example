PORT=3001

# Start locally: cd server && npm install && npm start
# Frontend dev server: npm run dev (http://localhost:5173)
# Health check: GET http://localhost:3001/health
# Send endpoint: POST http://localhost:3001/api/notifications/send

# Firebase Admin — verify staff ID tokens and send FCM (path to service account JSON)
# Path relative to server/ when running npm start from server/
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
FIREBASE_PROJECT_ID=matayehuda

# Payment server (server.js on port 5001) — same Firebase vars or use GOOGLE_APPLICATION_CREDENTIALS above
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com
# FRONTEND_URL=http://localhost:5173
# STAFF_PIN=

# CORS — comma-separated frontend origins (defaults include localhost:5173 and 127.0.0.1:5173)
CLIENT_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Skip notification tokens inactive for more than N days (default 90)
FCM_TOKEN_STALE_DAYS=90
