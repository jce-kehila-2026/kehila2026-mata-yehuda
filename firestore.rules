rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isActiveStaff() {
      return request.auth != null
        && exists(/databases/$(database)/documents/staff/$(request.auth.uid))
        && get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.is_active == true;
    }

    function isValidNotificationTokenWrite() {
      return request.resource.data.token == tokenId
        && request.resource.data.isActive is bool
        && request.resource.data.groups is list
        && request.resource.data.groups.size() > 0;
    }

    match /notification_tokens/{tokenId} {
      allow read: if isActiveStaff();
      allow create, update: if isValidNotificationTokenWrite();
      allow delete: if false;
    }

    match /notifications_log/{logId} {
      allow read: if isActiveStaff();
      allow write: if false;
    }

    // TODO: tighten rules for other collections in production.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
